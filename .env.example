# ─────────────────────────────────────────────────────────────────────────────
# NanoClaw — Railway Environment Variables
# Copy these into your Railway service's "Variables" tab.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# Your Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=123456:YOUR_BOT_TOKEN_HERE

# Your Telegram numeric user ID — ONLY this user can talk to the bot
# Find it with @userinfobot on Telegram
ADMIN_TELEGRAM_ID=YOUR_NUMERIC_TELEGRAM_ID

# ── Provider selection (pick ONE block) ───────────────────────────────────────

# ── Option A: NVIDIA NIM ──────────────────────────────────────────────────────
ZEROCLAW_PROVIDER=nvidia
NVIDIA_API_KEY=nvapi-YOUR_NVIDIA_KEY_HERE
# Model options (uncomment the one you want):
# ZEROCLAW_MODEL=deepseek-ai/deepseek-r1              ← DeepSeek-V4-Pro
# ZEROCLAW_MODEL=zhipuai/glm-5.1                      ← GLM-5.1
# ZEROCLAW_MODEL=qwen/qwen3.5-122b-a10b               ← Qwen3.5-122B
# ZEROCLAW_MODEL=qwen/qwen3-coder-480b-a35b-instruct  ← Coding: Qwen3-Coder
# ZEROCLAW_MODEL=microsoft/phi-4-mini-instruct        ← Coding: Phi-4-Mini
# ZEROCLAW_MODEL=meta/llama-3.3-70b-instruct          ← Coding: Llama 3.3 70B
# ZEROCLAW_MODEL=stabilityai/stable-diffusion-3.5-large ← Image: SD 3.5 Large
# ZEROCLAW_MODEL=black-forest-labs/flux.2-klein-4b    ← Image: FLUX.2 Klein

# ── Option B: EcomagentAI (Anthropic-compatible) ──────────────────────────────
# ZEROCLAW_PROVIDER=anthropic-custom:https://api.ecomagent.in/v1
# ECOMAGENT_API_KEY=YOUR_ECOMAGENT_KEY_HERE
# Model options for EcomagentAI:
# ZEROCLAW_MODEL=deepseek-ai/DeepSeek-V4-Pro
# ZEROCLAW_MODEL=zhipuai/GLM-5.1
# ZEROCLAW_MODEL=qwen/qwen3.5-122b-a10b
# ZEROCLAW_MODEL=anthropic/claude-sonnet-4-20250514
# ZEROCLAW_MODEL=qwen/qwen3-coder-480b-a35b-instruct
# ZEROCLAW_MODEL=microsoft/phi-4-mini-instruct
# ZEROCLAW_MODEL=meta/llama-3.3-70b-instruct

# ── Gateway ───────────────────────────────────────────────────────────────────
PORT=42617
ZEROCLAW_GATEWAY_PORT=42617
