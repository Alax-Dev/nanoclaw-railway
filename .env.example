# ─────────────────────────────────────────────────────────────────────────────
# NanoClaw — Railway Environment Variables
# Paste ALL of these into Railway → your service → Variables tab.
# You can set BOTH API keys — NanoClaw auto-swaps them when you switch models.
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram (Required) ───────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:YOUR_BOT_TOKEN_HERE
ADMIN_TELEGRAM_ID=YOUR_NUMERIC_TELEGRAM_ID   # find with @userinfobot

# ── API Keys — set BOTH so /use commands auto-swap keys ──────────────────────

# NVIDIA NIM key — used when /use deepseek, /use glm, /use qwen-coder, etc.
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx

# EcomagentAI key — used when /use claude, /use eco-deepseek, /use eco-glm, etc.
ECOMAGENT_API_KEY=your-ecomagent-api-key-here

# ── Starting provider + model (what boots first) ──────────────────────────────
# Change anytime from Telegram with /use <model> — no redeploy needed
ZEROCLAW_PROVIDER=nvidia
ZEROCLAW_MODEL=deepseek-ai/deepseek-r1

# ── Port (keep as-is) ─────────────────────────────────────────────────────────
PORT=42617
ZEROCLAW_GATEWAY_PORT=42617
